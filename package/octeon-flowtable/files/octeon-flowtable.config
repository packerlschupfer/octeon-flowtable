config octeon-flowtable 'settings'
	# Master switch for this init script (the module itself autoloads).
	option enabled '1'
	# Pin the Octeon Ethernet group IRQs one-per-core (the B5 tuning that
	# gets multi-flow to line rate via PIP GRPTAG hash-steering).
	option irq_spread '1'
	# Tail-drop AQM: per-egress-port in-flight byte cap (0 = off). e.g. for a
	# ~5 ms bound on a 1 Gbps link use 625000; on 100 Mbps use 62500.
	option aqm_limit '0'
	# Global hardware FAU byte/packet counters (read at
	# /sys/module/octeon_flowtable/parameters/hw_tx_{bytes,packets}). Small
	# per-packet cost, off by default.
	option fau_stats '0'
	# Verbose flow install/teardown logging (debug only).
	option verbose '0'
	# Strict VLAN matching: disable the wildcard-VID fallback lookup.
	# Keep 0 (default) when any offloaded zone uses bridged VLANs — the
	# kernel keys those flows untagged and the fallback is what matches them.
	# Set to 1 on plain-routing / 802.1Q-subinterface-only configs: it stops
	# tagged packets with an unconfigured VID from matching untagged-keyed
	# flows in the fast path (hardening).
	option vlan_strict '0'
