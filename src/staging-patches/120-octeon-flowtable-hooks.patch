 /**
+ * cvm_oct_transmit_qos - transmit a raw work-queue entry's packet via PKO
+ * @dev:    egress octeon netdev (selects PKO port + base queue)
+ * @work_queue_entry: the cvmx_wqe whose packet buffer to transmit
+ * @do_free: if non-zero, PKO frees the packet buffer back to its FPA pool on
+ *           completion and this function frees the WQE descriptor; if zero,
+ *           neither is freed (caller retains ownership)
+ * @qos:    output queue offset within the port's queue range
+ *
+ * For flow-offload: forward a received WQE out @dev without building an skb.
+ * Single-segment (word2.bufs == 1) packets only; the caller must not pass
+ * multi-buffer work here. Returns 0 on success, -1 on PKO failure (the buffer
+ * and WQE are freed on failure when do_free is set, to avoid leaking).
+ */
+int cvm_oct_transmit_qos(struct net_device *dev, void *work_queue_entry,
+			 int do_free, int qos)
+{
+	struct octeon_ethernet *priv = netdev_priv(dev);
+	struct cvmx_wqe *work = work_queue_entry;
+	union cvmx_pko_command_word0 pko_command;
+	union cvmx_buf_ptr hw_buffer;
+
+	pko_command.u64 = 0;
+	pko_command.s.n2 = 1;	/* Don't pollute L2 with the outgoing packet */
+	pko_command.s.segs = work->word2.s.bufs;
+	pko_command.s.total_bytes = work->word1.len;
+	pko_command.s.dontfree = do_free ? 0 : 1;
+
+	if (cvm_oct_flow_aqm_fau) {
+		/* Tail-drop AQM input: PKO atomically subtracts this packet's
+		 * byte count from a per-port 64-bit in-flight FAU counter when it
+		 * transmits. The flow-offload module adds the same when queuing,
+		 * so the counter tracks bytes handed to PKO but not yet on the
+		 * wire. reg0 == 0 (the default) disables it. */
+		pko_command.s.reg0 = cvm_oct_flow_aqm_fau + priv->port * 8;
+		pko_command.s.size0 = CVMX_FAU_OP_SIZE_64;
+		pko_command.s.subone0 = 0;	/* subtract total_bytes */
+	}
+
+	hw_buffer = work->packet_ptr;
+
+	cvmx_pko_send_packet_prepare(priv->port, priv->queue + qos,
+				     CVMX_PKO_LOCK_CMD_QUEUE);
+
+	if (unlikely(cvmx_pko_send_packet_finish(priv->port, priv->queue + qos,
+						 pko_command, hw_buffer,
+						 CVMX_PKO_LOCK_CMD_QUEUE))) {
+		if (do_free)
+			cvm_oct_free_work(work);
+		return -1;
+	}
+
+	if (do_free) {
+		/* PKO frees the packet buffer (dontfree=0). Free the WQE
+		 * descriptor itself back to the WQE pool.
+		 */
+		cvmx_fpa_free(work, CVMX_FPA_WQE_POOL, 1);
+	}
+
+	return 0;
+}
+EXPORT_SYMBOL(cvm_oct_transmit_qos);
